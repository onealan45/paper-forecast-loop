# Paper Forecast Loop example environment.
#
# Copy to `.env` only for local experiments. Do not commit `.env`.
# M6B does not require real broker or notification credentials.

FORECAST_LOOP_ENV=local
FORECAST_LOOP_BROKER_MODE=INTERNAL_PAPER
FORECAST_LOOP_STORAGE_DIR=paper_storage/hourly-paper-forecast/coingecko/BTC-USD

# Reserved for future sandbox/paper integrations. Leave blank in this repo.
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
TELEGRAM_BOT_TOKEN=
